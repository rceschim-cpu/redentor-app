rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Usuários — qualquer autenticado pode ler; escrita no próprio perfil
    // ou por outro autenticado (para admin alterar role de outros usuários)
    match /users/{uid} {
      allow read, write: if request.auth != null;
    }

    // Membros — leitura para autenticados, escrita para autenticados
    match /members/{id} {
      allow read, write: if request.auth != null;
    }

    // Grupos
    match /groups/{id} {
      allow read, write: if request.auth != null;
    }

    // Memberships (subcoleção de grupos)
    match /groups/{groupId}/memberships/{id} {
      allow read, write: if request.auth != null;
    }

    // Materiais
    match /group_materials/{id} {
      allow read, write: if request.auth != null;
    }

    // Notificações — cada usuário lê/escreve as próprias
    match /notifications/{uid}/items/{id} {
      allow read, write: if request.auth != null;
    }
  }
}
